# Microsoft Entra External ID Configuration
# Copy this file to .azure-entra.env and fill in your values
# Get these from Azure Portal → App Registrations → Your API App

# Azure Tenant Information
TENANT_ID=your-tenant-id-here
CIAM_DOMAIN=your-ciam-domain.onmicrosoft.com
AUTHORITY=https://your-ciam-domain.ciamlogin.com/your-tenant-id

# API Application (Backend)
API_CLIENT_ID=your-api-app-client-id
API_CLIENT_SECRET=your-api-app-client-secret

# Extension App ID (for custom attributes)
# Format: Remove dashes from the Object ID of your b2c-extensions-app
EXTENSION_APP_ID=your-extension-app-id-without-dashes

# Frontend Applications
USER_PORTAL_CLIENT_ID=your-user-portal-app-client-id
ADMIN_PORTAL_CLIENT_ID=your-admin-portal-app-client-id
