# API Configuration
VITE_API_URL=http://localhost:5001
VITE_API_BASE_URL=http://localhost:5001

# Authentication Mode
# Set to 'true' for E2E test mode (bypasses Keycloak, uses direct API auth)
# Leave unset or set to 'false' for production mode (uses Keycloak with OAuth support)
VITE_E2E_MODE=false

# Keycloak Configuration (only needed when VITE_E2E_MODE is false or unset)
# Required for Google OAuth sign-in and production authentication
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=gymnastics
VITE_KEYCLOAK_CLIENT_ID=user-portal
