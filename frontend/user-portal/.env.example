# API Configuration
VITE_API_URL=http://localhost:5001
VITE_API_BASE_URL=http://localhost:5001

# Authentication Mode
# Set to 'true' for E2E test mode (bypasses authentication, uses direct API auth)
# Leave unset or set to 'false' for production mode (uses Microsoft Entra External ID with OAuth support)
VITE_E2E_MODE=false

# Microsoft Entra External ID Configuration (only needed when VITE_E2E_MODE is false or unset)
# Required for Google OAuth, Microsoft OAuth, and production authentication
# Get these values from: infrastructure/external-id/outputs.sh after running terraform apply
VITE_EXTERNAL_ID_TENANT_ID=
VITE_EXTERNAL_ID_CLIENT_ID=
VITE_EXTERNAL_ID_AUTHORITY=
VITE_API_CLIENT_ID=
VITE_REDIRECT_URI=http://localhost:5173/auth/callback
